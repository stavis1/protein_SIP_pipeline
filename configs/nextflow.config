executor {
    $slurm {
        queueSize = 500 //edit this
        jobName = {"${task.process}_${task.hash}"}
        submitRateLimit = '10sec'
    }

    $local {
        cpus = 4
        queueSize = 4
        memory = 10.GB
    }
}

apptainer {
    enabled = true
    cacheDir = "$projectDir/cache/"
    autoMounts = true
}

process {
    //global options for all processes
    executor = 'slurm'
    errorStrategy = {task.attempt <= 3 ? 'retry' : 'ignore'}
    maxRetries = 4

    //edit these options for your account and cluster details
    //delete any option you don't need to use
    clusterOptions = "-N 1 --partition=partition_name --qos=quality_of_service --account=account_name"
    
    //process specific options
    //if you run into resource constriants change these values 
        withLabel: 'small' {
        cpus = 1
        memory = 2.GB
        time = { task.exitStatus == 140 ? 2.h : 1.h }
    }

        withLabel: 'medium' {
        cpus = 3
        memory = 6.GB
        time = { task.exitStatus == 140 ? 2.h : 1.h }
    }

        withLabel: 'percolator' {
        errorStrategy = { task.exitStatus == 1234 ? 'ignore' : {task.attempt <= 3 ? 'retry' : 'ignore'} }
        cpus = 3
        memory = { 20.GB + (10.GB * (task.attempt - 1)) }
        time = { task.exitStatus == 140 ? 2.h : 1.h }
    }

        withLabel: 'large' {
        cpus = 4
        memory = { 10.GB + (5.GB * task.attempt) }
        time = { task.exitStatus == 140 ? 6.h : 3.h }
    }

        withLabel: 'classifier' {
        cpus = 32
        memory = 64.GB
        time = { task.exitStatus == 140 ? 12.h : 6.h }
    }
}
